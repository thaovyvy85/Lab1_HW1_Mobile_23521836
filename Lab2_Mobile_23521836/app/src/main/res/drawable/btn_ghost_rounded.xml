<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#334ECDC4"/><corners android:radius="50dp"/>
            <stroke android:width="1.5dp" android:color="#554ECDC4"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF"/><corners android:radius="50dp"/>
            <stroke android:width="1.5dp" android:color="#33FFFFFF"/>
        </shape>
    </item>
</selector>