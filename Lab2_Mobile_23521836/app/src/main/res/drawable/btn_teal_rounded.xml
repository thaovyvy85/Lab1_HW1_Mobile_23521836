<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#26C6DA" android:endColor="#00ACC1" android:angle="135"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1A8899"/><corners android:radius="50dp"/>
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#4ECDC4" android:endColor="#26C6DA" android:angle="135"/>
                    <corners android:radius="50dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>